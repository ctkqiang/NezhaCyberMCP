APP_NAME=NezhaCyberMCP

# Database Configuration 
DB_HOST=xxxxxxxxxx
# You can change this to 3306 if you are using MySQL, 
# 5432 if you are using PostgreSQL, 
# 1433 if you are using SQL Server, 
# 1521 if you are using Oracle Database , 
# 8812 if you are using QuestDB
DB_PORT=xxxxxxxxxx
DB_USER=xxxxxxxxxx
DB_PASSWORD=xxxxxxxxxx
DB_NAME=xxxxxxxxxx
DB_SSL=xxxxxxxxxx
DB_TIMEZONE=xxxxxxxxxx

DB_SQLITE=xxxxxxxxxx

# Github Token
GITHUB_TOKEN=xxxxxxxxxx

# If using AWS
AWS_ACCESS_KEY_ID=xxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxx
AWS_REGION=xxxxxxxxxx

# AWS Secrets Manager
# In AWS mode (IS_AWS=true or Lambda runtime), the application loads all
# configuration from Secrets Manager instead of this .env file.
#
# Set exactly ONE of the following:
#   SECRET_ARN  — full ARN (recommended, avoids cross-region ambiguity)
#                 format: arn:aws:secretsmanager:<region>:<account-id>:secret:<name>
#   SECRET_NAME — secret name only (simpler, same-region deployments)
#
# The secret value must be a flat JSON object whose keys match the env var
# names above (DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME, etc.).
#
# In Lambda, set SECRET_ARN as a Lambda environment variable — do NOT put
# the real ARN in this file or commit it to source control.
SECRET_ARN=xxxxxxxxxx
# SECRET_NAME=xxxxxxxxxx

# AWS S3 .env Source (highest priority in AWS mode)
# When both S3_ENV_BUCKET and S3_ENV_KEY are set, the application downloads
# the .env file from S3 at startup instead of using Secrets Manager.
#
# Setup steps:
#   1. Upload your .env file to a private S3 bucket (Block all public access ON)
#   2. Set S3_ENV_BUCKET to the bucket name
#   3. Set S3_ENV_KEY to the object key (default: ".env")
#   4. Grant the Lambda execution role s3:GetObject on that object:
#        Resource: arn:aws:s3:::<bucket>/<key>
#
# Loading priority in AWS mode:
#   S3 .env  >  Secrets Manager  >  Lambda system environment variables
#
# In Lambda, set these as Lambda environment variables — do NOT commit real
# bucket names or keys to source control.
S3_ENV_BUCKET=xxxxxxxxxx
S3_ENV_KEY=.env
